# Telegram API Credentials
# Obtené estos datos en https://my.telegram.org/apps
TELEGRAM_API_ID=TU_API_ID_AQUI
TELEGRAM_API_HASH=TU_API_HASH_AQUI

# Chat target (ID numérico del grupo/canal)
TELEGRAM_TARGET_CHAT=-1234567890

# Nombre del archivo de sesión (se genera automáticamente al loguear)
TELEGRAM_SESSION_NAME=sesion_telegram

# Directorio donde se guardan las descargas
OUTPUT_DIR=~/Descargas/Telegram_Masivo
